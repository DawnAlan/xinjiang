<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cj.middleDatabase.func.modular.lzz.lzzRainfallStation.mapper.LzzRainfallStationMapper">
    <select id="getRealTimeRainfall" resultType="com.cj.middleDatabase.func.modular.dto.RealTimeRainfallRes">
        SELECT TREE_ID as ID,STATION_NAME, RAINFALL
        FROM LZZ_RAINFALL_STATION
        <where>
            and TO_CHAR(TIME,'YYYY-MM-DD hh24') BETWEEN #{startTime} AND #{endTime}
            <if test="ids!=null and ids.size()>0">
                and TREE_ID in
                <foreach item="item" collection="ids" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
        </where>
        limit #{num} order by TIME desc
    </select>
    <select id="getRealTimeRainfallByDate" resultType="com.cj.middleDatabase.func.modular.dto.RealTimeRainfallRes">
        SELECT TREE_ID as ID,STATION_NAME, RAINFALL
        FROM LZZ_RAINFALL_STATION
        <where>
            and RECORD_TIME = #{date}
            <if test="ids!=null and ids.size()>0">
                and TREE_ID in
                <foreach item="item" collection="ids" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
        </where>
        order by TIME desc
    </select>
</mapper>
